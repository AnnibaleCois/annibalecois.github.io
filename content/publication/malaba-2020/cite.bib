@article{Malaba2020,
 abstract = {High blood pressure (BP) late in pregnancy is associated with preterm delivery (PTD); BP has also been associated with HIV and antiretroviral therapy (ART), but whether the relationship between BP assessed longitudinally over pregnancy and PTD and low birthweight (LBW) is modified by HIV/ART is unclear. We hypothesise the presence of distinctive BP trajectories and their association with adverse birth outcomes may be mediated by HIV/ART status.},
 author = {Malaba, Thokozile R. and Cois, Annibale and Madlala, Hlengiwe P. and Matjila, Mushi and Myer, Landon and Newell, Marie-Louise and for the PIMS Study Group},
 copyright = {All rights reserved},
 doi = {10.1186/s12884-020-03411-y},
 file = {Malaba2020:C\:\\Users\\Annibale\\Google Drive\\Documents\\References\\Annibale\\Malaba2020.pdf:application/pdf},
 journal = {BMC Pregnancy and Childbirth},
 number = {1},
 pages = {742--742},
 title = {Blood pressure trajectories during pregnancy and associations with adverse birth outcomes among HIV-infected and HIV-uninfected women in South Africa: a group-based trajectory modelling approach},
 url = {https://doi.org/10.1186/s12884-020-03411-y},
 volume = {20},
 year = {2020}
}

