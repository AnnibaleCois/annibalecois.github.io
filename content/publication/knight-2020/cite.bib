@article{Knight2020,
 abstract = {The stated intention to eliminate silicosis from the South African goldmining industry as well as current programmes to find and compensate ex-miners with silicosis require an understanding of variation in silicosis prevalence across the industry. We aimed to identify the predictors of radiological silicosis in a large sample of working miners across gold mines in South Africa.},
 author = {Knight, Dave and Ehrlich, Rodney and Cois, Annibale and Fielding, Katherine and Grant, Alison D. and Churchyard, Gavin},
 copyright = {All rights reserved},
 file = {Knight2020:C\:\\Users\\Annibale\\Google Drive\\Documents\\References\\Annibale\\Knight2020.pdf:application/pdf},
 journal = {BMC Public Health},
 number = {1},
 pages = {829--829},
 title = {Predictors of silicosis and variation in prevalence across mines among employed gold miners in South Africa},
 url = {https://doi.org/10.1186/s12889-020-08876-2},
 volume = {20},
 year = {2020}
}

